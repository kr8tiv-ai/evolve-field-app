# ── Secrets & deploy config — NEVER commit ─────────────────────────────
# NOTE: .gitignore has NO inline comments. A trailing "# ..." becomes part of
# the pattern, so every rule below keeps its comment on its own line.

# contains the private Apps Script scriptId
.clasp.json
.clasprc.json
# generated copies with the real IDs filled in
deploy-local/
*.local
*.secret
.env
.env.*
secrets.json
router-url.txt
*-secret*.txt

# ── Local build / preview artifacts ────────────────────────────────────
# local PDF/email preview renders
_*.html
# local audit/research notes
_*.md
# local sync tooling — _sanitize.js holds the real→placeholder map
_*.js
*_preview.*

# ── OS / editor ────────────────────────────────────────────────────────
node_modules/
.DS_Store
Thumbs.db
.vscode/
.idea/
